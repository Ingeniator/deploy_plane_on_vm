# ================================================================
# Plane AIO — Production Environment
# cp .env.example .env  then fill in every value marked CHANGE_ME
# Registry credentials are NOT stored here — deploy.sh prompts for them.
# ================================================================

# --- Private registry ---
REGISTRY=docker.io

# --- Release tag (matches what was pushed to the registry) ---
APP_RELEASE=stable

# --- VM IP address ---
# Use the VM's IP, e.g. 192.168.1.100 or 10.0.0.5
DOMAIN_NAME=CHANGE_ME_IP
APP_DOMAIN=CHANGE_ME_IP
WEB_URL=http://CHANGE_ME_IP
CORS_ALLOWED_ORIGINS=http://CHANGE_ME_IP
API_BASE_URL=http://CHANGE_ME_IP:3004
SITE_ADDRESS=:80
LISTEN_HTTP_PORT=80
LISTEN_HTTPS_PORT=443

# --- PostgreSQL ---
POSTGRES_USER=plane
POSTGRES_DB=plane
POSTGRES_PASSWORD=CHANGE_ME
DATABASE_URL=postgresql://plane:CHANGE_ME@plane-db/plane

# --- Valkey (Redis-compatible) ---
REDIS_URL=redis://plane-redis:6379/

# --- RabbitMQ ---
RABBITMQ_USER=plane
RABBITMQ_PASSWORD=CHANGE_ME
RABBITMQ_VHOST=plane
AMQP_URL=amqp://plane:CHANGE_ME@plane-mq:5672/plane

# --- MinIO (S3-compatible object storage) ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
AWS_S3_ENDPOINT_URL=http://plane-minio:9000
AWS_S3_BUCKET_NAME=uploads
BUCKET_NAME=uploads
USE_MINIO=1
FILE_SIZE_LIMIT=5242880
MINIO_ENDPOINT_SSL=0

# --- App secrets (generate with: openssl rand -hex 32) ---
SECRET_KEY=CHANGE_ME
LIVE_SERVER_SECRET_KEY=CHANGE_ME

# --- App tuning ---
DEBUG=0
GUNICORN_WORKERS=2
API_KEY_RATE_LIMIT=60/minute
